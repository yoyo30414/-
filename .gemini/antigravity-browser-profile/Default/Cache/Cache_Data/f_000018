@charset "utf-8";
/*****************************************
** global
/*****************************************/
h1{
	font-size:16px;
	color:#977347;
}
h1 span{
	margin:0 0 0 8px;
	font-size:12px;
}

h2.util_1{
	background:url(../images/icon/icon_ring.jpg) no-repeat 0 -36px;
	text-indent:25px;
	font-size:16px;
	color:#4D4D4D;
	margin:0 0 20px 0;
}

h2.util_2{
	display:block;
	font-size:16px;
	color:#333;
	position:relative;
	margin:0 0 20px 0;
	padding:0 0 5px 0;
	border-bottom:1px dotted #CCC;
}
h2.util_2 .id{
	position:absolute;
	right:0;
}

h2.util_3{
	position:relative;
	font-size:16px;
	color:#333;
	margin:0 0 20px 0;
}
h2.util_3 span{
	display:block;
	width:80%;
}
h2.util_3 span.date{
	width:auto;
	font-weight:normal;
	font-size:13px;
	color:#999;
	position:absolute;
	top:0;
	right:0;
}
h2.util_4{
	display:block;
	font-size:18px;
	color:#333;
	position:relative;
	margin:10px 0 16px 0;
	padding:0 0 5px 0;
}
h2.util_4:before{
	display:block;
	content:".";
	font-size:0;
	background:url(../images/orange-arrow.png) no-repeat;
	width:25px;
	height:40px;
	position:absolute;
	left:-20px;
	top:5px;
}
h2.util_6{
	display:block;
	font-size:18px;
	color:#333;
	position:relative;
	margin:10px 0 16px 0;
	padding:0 0 5px 0;
}
h2.util_6:before{
	display:block;
	content:".";
	font-size:0;
	background:url(../images/orange-arrow.png) no-repeat;
	width:25px;
	height:40px;
	position:absolute;
	left:-20px;
	top:5px;
}
h2.util_5{
	display:block;
	font-size:18px;
	color:#333;
	position:relative;
	margin:10px 0 10px 0;
	padding:0 0 5px 0;
}
h2.util_5:before{
	display:block;
	content:".";
	font-size:0;
	background:url(../images/orange-arrow.png) no-repeat;
	width:25px;
	height:40px;
	position:absolute;
	left:-20px;
	top:5px;
}
h3{
	font-size:13px;
	margin:0 0 20px 0;
	position:relative;
}
h3 span{
	background:#FFF;
	padding:0 10px 0 0;
	position:relative;
	z-index:3;
}
h3:after{
	display:block;
	width:100%;
	content:".";
	font-size:0;
	height:1px;
	background:#d2d2d2;
	position:absolute;
	top:50%;
	z-index:1;
}

.util_4{
	display:block;
	font-size:18px;
	color:#333;
	position:relative;
	margin:10px 0 16px 0;
	padding:0 0 5px 0;
