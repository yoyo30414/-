/*****************************************
** product
/*****************************************/
ul.product{width:100%;}
ul.product li{
	float:left;
	display:block;
	width:210px;
	height:295px;
	margin:0 0 20px 20px;
	padding:5px;
	border:1px solid #CCC;
	overflow:hidden;
}
ul.product a.photo{
	display:block;
	font-size:13px;
	color:#707070;
	background:#000;
	position:relative;
	margin:0 0 45px 0;
}
ul.product a.photo span{
	display:block;
	position:absolute;
	height:33px;
	overflow:hidden;
}
ul.product a.photo:hover{color:#333;}
ul.product a.photo img{
	display:block;
	width:210px;
	height:210px;
	margin:0 0 5px 0;
}
ul.product a.photo:hover img{
	opacity:0.7;
	filter:alpha(opacity=70);
}

ul.product .price{
	color:#ee86ad;
	font-weight:bold;
	position:relative;
	top:-5px;
}
ul.product .price span{
	font-size:18px;
	margin:0 0 0 5px;
}

ul.product .ccWrap{font-size:0;}
ul.product span.cc{margin:0 3px 0 0;}

