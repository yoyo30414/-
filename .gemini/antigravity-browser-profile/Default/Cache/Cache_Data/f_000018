/*****************************************
** searchGroup
/*****************************************/
ul.searchGroup_1{
	width:100%;
	display:block;
	overflow:hidden;
}
ul.searchGroup_1 li{
	float:left;
	display:block;
	width:30%;
	height:20px;
	line-height:20px;
	margin:0 5px 5px 0;
	overflow:hidden;
}
ul.searchGroup_1 li span.cc{
	margin:0 5px 0 0;
	position:relative;
	top:3px;
}

ul.searchGroup_2{
	width:100%;
	display:block;
	margin:0 0 0 20px;
	overflow:hidden;
}
ul.searchGroup_2 li{
	float:left;
	display:block;
	width:20%;
