/*****************************************
** pager
/*****************************************/
.pager{text-align:center;}
.pager a{
	font-size:12px;
	text-align:center;
	color:#999;
	display:inline-block;
	width:16px;
	height:16px;
	line-height:16px;
	margin:0 1px;
}
.pager a.current, .pager a:hover{
	color:#000;
	font-weight:bold;
}
.pager a.first, .pager a.prev,
.pager a.last, .pager a.next{
	background:#f9fcfe;
	border:1px solid #dcdcdc;
	border-radius:3px;
	font-weight:bold;
	font-size:13px;
	color:#282828;
}

